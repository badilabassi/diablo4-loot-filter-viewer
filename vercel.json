{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm install --include=optional",
  "buildCommand": "npm run typecheck",
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }],
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "{app/**,node_modules/remix/**,node_modules/@remix-run/**,node_modules/@oxc-project/**,node_modules/lightningcss*/**,node_modules/oxc-*/**}"
    }
  }
}
