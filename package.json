  "engines": {
    "node": ">=24.3.0"
  },
  "dependencies": {
    "remix": "3.0.0-beta.2",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "esbuild": "^0.28.0",
    "typescript": "~6.0.2"
  }
}
